{
  "name": "opencode Development Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "HTTPS_PROXY": "http://192.168.1.101:14005"
    }
  },
  "runArgs": [
    "-v", "/var/run/docker.sock:/var/run/docker.sock",
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-python.python",
        "golang.go"
      ]
    }
  }
}
